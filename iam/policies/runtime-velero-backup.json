{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "VeleroListBucket",
      "Effect": "Allow",
      "Action": [
        "s3:ListBucket",
        "s3:GetBucketLocation"
      ],
      "Resource": "arn:aws:s3:::793496711039-talos-cluster-velero"
    },
    {
      "Sid": "VeleroObjectOps",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:PutObject",
        "s3:DeleteObject",
        "s3:AbortMultipartUpload",
        "s3:ListMultipartUploadParts"
      ],
      "Resource": "arn:aws:s3:::793496711039-talos-cluster-velero/*"
    }
  ]
}
