{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ManageKmsAlertEventRule",
      "Effect": "Allow",
      "Action": [
        "events:PutRule",
        "events:DeleteRule",
        "events:DescribeRule",
        "events:EnableRule",
        "events:DisableRule",
        "events:ListRules",
        "events:PutTargets",
        "events:RemoveTargets",
        "events:ListTargetsByRule",
        "events:TagResource",
        "events:UntagResource",
        "events:ListTagsForResource"
      ],
      "Resource": "arn:aws:events:*:793496711039:rule/talos-cluster-kms-alerts*"
    },
    {
      "Sid": "ManageKmsAlertSnsTopic",
      "Effect": "Allow",
      "Action": [
        "sns:CreateTopic",
        "sns:DeleteTopic",
        "sns:GetTopicAttributes",
        "sns:SetTopicAttributes",
        "sns:Subscribe",
        "sns:Unsubscribe",
        "sns:ConfirmSubscription",
        "sns:GetSubscriptionAttributes",
        "sns:ListSubscriptionsByTopic",
        "sns:ListTopics",
        "sns:TagResource",
        "sns:UntagResource",
        "sns:ListTagsForResource"
      ],
      "Resource": "arn:aws:sns:*:793496711039:talos-cluster-kms-alerts*"
    },
    {
      "Sid": "DescribeEventBus",
      "Effect": "Allow",
      "Action": [
        "events:DescribeEventBus",
        "events:ListRules"
      ],
      "Resource": "*"
    }
  ]
}
