{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ListBackendBucketScoped",
      "Effect": "Allow",
      "Action": "s3:ListBucket",
      "Resource": "arn:aws:s3:::793496711039-terraform",
      "Condition": {
        "StringLike": {
          "s3:prefix": [
            "nwarila-platform/talos-cluster/*"
          ]
        }
      }
    },
    {
      "Sid": "ReadWritePlatformState",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:GetObjectVersion",
        "s3:PutObject"
      ],
      "Resource": "arn:aws:s3:::793496711039-terraform/nwarila-platform/talos-cluster/platform.tfstate"
    },
    {
      "Sid": "ManagePlatformStateLock",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:PutObject",
        "s3:DeleteObject"
      ],
      "Resource": "arn:aws:s3:::793496711039-terraform/nwarila-platform/talos-cluster/platform.tfstate.tflock"
    },
    {
      "Sid": "ReadBootstrapStateForRemoteStateInputs",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:GetObjectVersion"
      ],
      "Resource": "arn:aws:s3:::793496711039-terraform/nwarila-platform/talos-cluster/bootstrap.tfstate"
    },
    {
      "Sid": "DenyMutatingBootstrapState",
      "Effect": "Deny",
      "Action": [
        "s3:PutObject",
        "s3:DeleteObject",
        "s3:DeleteObjectVersion"
      ],
      "Resource": "arn:aws:s3:::793496711039-terraform/nwarila-platform/talos-cluster/bootstrap.tfstate"
    },
    {
      "Sid": "DenyPlatformStateDelete",
      "Effect": "Deny",
      "Action": [
        "s3:DeleteObject",
        "s3:DeleteObjectVersion"
      ],
      "Resource": "arn:aws:s3:::793496711039-terraform/nwarila-platform/talos-cluster/platform.tfstate"
    },
    {
      "Sid": "DenyUnencryptedPuts",
      "Effect": "Deny",
      "Action": "s3:PutObject",
      "Resource": "arn:aws:s3:::793496711039-terraform/nwarila-platform/talos-cluster/*",
      "Condition": {
        "StringNotEquals": {
          "s3:x-amz-server-side-encryption": "AES256"
        }
      }
    },
    {
      "Sid": "DenyPutsWithoutEncryptionHeader",
      "Effect": "Deny",
      "Action": "s3:PutObject",
      "Resource": "arn:aws:s3:::793496711039-terraform/nwarila-platform/talos-cluster/*",
      "Condition": {
        "Null": {
          "s3:x-amz-server-side-encryption": "true"
        }
      }
    }
  ]
}
