# =============================================================================
# TDNHQ-TALCL01 Cluster Configuration
# Sourced by all automation scripts. Keep syntax bash-compatible.
# =============================================================================

# -- Cluster Identity ---------------------------------------------------------
# CLUSTER_NAME is the Talos cluster identifier (cluster.clusterName in machine
# configs and the context name in talosconfig/kubeconfig). It's "talos-cluster"
# because that's the talosctl-gen-config default the live cluster was
# bootstrapped with. The site/asset identifier "TDNHQ-TALCL01" is a separate
# label and lives only in README/CLAUDE.md/systems — it never appears in
# generated machine config.
CLUSTER_NAME="talos-cluster"
CLUSTER_ENDPOINT="https://10.69.112.62:6443"

# -- Version Pinning ----------------------------------------------------------
TALOS_VERSION="v1.12.5"
KUBERNETES_VERSION="v1.35.2"

# -- Network ------------------------------------------------------------------
CLUSTER_VIP="10.69.112.62"
CLUSTER_GATEWAY="10.69.112.1"
CLUSTER_NETMASK="24"

# -- Node Inventory (hostname:ip) --------------------------------------------
# Hostnames are the short forms used by the live cluster — see
# docs/decision-records/repo/0002-use-short-talos-hostnames.md.
# Cross-reference to site-level asset names (TDNHQ-TLO*) lives in `systems`.
CP_NODES="cp1:10.69.112.63 cp2:10.69.112.64 cp3:10.69.112.65"
WORKER_NODES="w1:10.69.112.68 w2:10.69.112.69 w3:10.69.112.70"
BOOTSTRAP_NODE="cp1:10.69.112.63"

# -- Talos Install ------------------------------------------------------------
# Schematic the live cluster was actually built from (confirmed against
# machine.install.image on every node 2026-05-25). The previous value
# a9af4ea9... did not match live state and would have triggered a re-image
# on next apply.
# Look up schematic contents at: https://factory.talos.dev/?image=36cd6536eaec8ba802be2d38974108359069cedba8857302f69792b26b87c010
TALOS_SCHEMATIC_ID="36cd6536eaec8ba802be2d38974108359069cedba8857302f69792b26b87c010"
TALOS_INSTALL_IMAGE="factory.talos.dev/installer/${TALOS_SCHEMATIC_ID}:${TALOS_VERSION}"

# -- Cilium CNI ---------------------------------------------------------------
CILIUM_VERSION="1.16.6"

# -- S3 Configuration ---------------------------------------------------------
# Bucket has versioning enabled — a bad push doesn't permanently destroy good
# state. Default encryption is AES256 at the bucket level; the sync script
# additionally requests --sse aws:kms per object.
S3_BUCKET="793496711039-terraform"
S3_PREFIX="nwarila-platform/talos-cluster/"


LOCAL_S3_DIR=".s3"
