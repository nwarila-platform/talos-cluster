# Allow ingress from the Cilium Gateway API gateway — for tenant
# workloads exposed externally via HTTPRoute. The Cilium gateway
# controller deploys gateway proxy pods that need to reach the
# tenant's service Pods.
#
# Cilium creates per-Gateway proxy pods in `kube-system` (configurable
# via gateway-api-secrets-namespace; default `cilium-secrets` for TLS
# secrets, with the proxy itself in `kube-system`). Selector targets
# any pod in kube-system labeled as a gateway proxy.
#
# If the tenant doesn't use Gateway API ingress (e.g., internal-only
# workload), this NetworkPolicy can be omitted.
apiVersion: networking.k8s.io/v1
kind: NetworkPolicy
metadata:
  name: allow-gateway-ingress
  namespace: __TENANT_NAMESPACE__
spec:
  podSelector: {}
  policyTypes:
    - Ingress
  ingress:
    - from:
        - namespaceSelector:
            matchLabels:
              kubernetes.io/metadata.name: kube-system
          podSelector:
            matchLabels:
              io.cilium.gateway/owning-gateway: "true"
