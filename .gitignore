# =============================================================================
# Deny-all .gitignore strategy per nwarila-platform/.github ADR-0003.
# Anything not explicitly allowlisted below is ignored.
# See: docs/decision-records/org/0003-use-deny-all-gitignore-strategy.md
# =============================================================================
**

# Allow the allowlist itself so tracked scope stays auditable.
!/.gitignore

# -- Top-level repo files -----------------------------------------------------
!/.editorconfig
!/.pre-commit-config.yaml
!/AGENTS.md
!/CLAUDE.md
!/Makefile
!/README.md
!/systems

# -- Flux: GitOps controllers + cluster-specific bootstrap ---------------------
!/clusters/
!/clusters/talos-cluster/
!/clusters/talos-cluster/kustomization.yaml
!/clusters/talos-cluster/flux-system/
!/clusters/talos-cluster/flux-system/gotk-components.yaml
!/clusters/talos-cluster/flux-system/gotk-sync.yaml
!/clusters/talos-cluster/flux-system/kustomization.yaml
!/clusters/talos-cluster/apps/
!/clusters/talos-cluster/apps/kustomization.yaml
!/clusters/talos-cluster/apps/gateway-api/
!/clusters/talos-cluster/apps/gateway-api/gatewayclass.yaml
!/clusters/talos-cluster/apps/gateway-api/kustomization.yaml
!/clusters/talos-cluster/apps/kubelet-csr-approver/
!/clusters/talos-cluster/apps/kubelet-csr-approver/helmrelease.yaml
!/clusters/talos-cluster/apps/kubelet-csr-approver/helmrepository.yaml
!/clusters/talos-cluster/apps/kubelet-csr-approver/kustomization.yaml
!/clusters/talos-cluster/apps/metrics-server/
!/clusters/talos-cluster/apps/metrics-server/helmrelease.yaml
!/clusters/talos-cluster/apps/metrics-server/helmrepository.yaml
!/clusters/talos-cluster/apps/metrics-server/kustomization.yaml

# -- GitHub configuration -----------------------------------------------------
!/.github/
!/.github/CODEOWNERS
!/.github/renovate.json5
!/.github/workflows/
!/.github/workflows/deploy.yaml
!/.github/workflows/drift.yaml
!/.github/workflows/etcd-snapshot.yaml
!/.github/workflows/kubescape.yaml
!/.github/workflows/security.yaml
!/.github/workflows/validate.yaml

# -- Cluster: Talos machine config patches + version pinning ------------------
!/cluster/
!/cluster/config.env
!/cluster/patches/
!/cluster/patches/common.yaml
!/cluster/patches/controlplane.yaml
!/cluster/patches/cp1.yaml
!/cluster/patches/cp2.yaml
!/cluster/patches/cp3.yaml
!/cluster/patches/volumes.yaml
!/cluster/patches/w1.yaml
!/cluster/patches/w2.yaml
!/cluster/patches/w3.yaml
!/cluster/patches/worker.yaml

# -- Addons: Helm values and Kubernetes manifests -----------------------------
!/addons/
!/addons/cilium/
!/addons/cilium/values.yaml
!/addons/kubelet-csr-approver/
!/addons/kubelet-csr-approver/values.yaml
!/addons/longhorn/
!/addons/longhorn/values.yaml
!/addons/metrics-server/
!/addons/metrics-server/values.yaml

# -- Scripts: automation invoked by the Makefile ------------------------------
!/scripts/
!/scripts/agent-loop.ps1
!/scripts/agent-loop.sh
!/scripts/apply.sh
!/scripts/bootstrap.sh
!/scripts/diff-vs-live.py
!/scripts/drift-check.sh
!/scripts/etcd-snapshot.sh
!/scripts/generate.sh
!/scripts/kubescape-scan.sh
!/scripts/kubescape-json-to-sarif.py
!/scripts/health.sh
!/scripts/s3-sync.sh
!/scripts/upgrade.sh

# -- Docs: org-mirrored ADRs + repo/template ADR skeleton ---------------------
!/docs/
!/docs/compliance/
!/docs/compliance/README.md
!/docs/decision-records/
!/docs/decision-records/README.md
!/docs/decision-records/org/
!/docs/decision-records/org/0001-use-architecture-decision-records.md
!/docs/decision-records/org/0002-adopt-diataxis-documentation-framework.md
!/docs/decision-records/org/0003-use-deny-all-gitignore-strategy.md
!/docs/decision-records/org/0004-use-renovate-for-dependency-updates.md
!/docs/decision-records/repo/
!/docs/decision-records/repo/.gitkeep
!/docs/decision-records/repo/0001-renovate-without-template-lineage.md
!/docs/decision-records/repo/0002-use-short-talos-hostnames.md
!/docs/decision-records/repo/0003-repo-as-cluster-source-of-truth.md
!/docs/decision-records/repo/0004-capture-longhorn-volume-config-in-talos.md
!/docs/decision-records/repo/0005-kubelet-csr-approver.md
!/docs/decision-records/repo/0006-etcd-snapshot-automation.md
!/docs/decision-records/repo/0007-capture-longhorn-as-managed-addon.md
!/docs/decision-records/repo/0008-gitops-via-flux.md
!/docs/decision-records/repo/0009-stig-cis-compliance-baseline.md
!/docs/decision-records/template/
!/docs/decision-records/template/.gitkeep
