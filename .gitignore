# =============================================================================
# Deny-all .gitignore strategy per nwarila-platform/.github ADR-0003.
# Anything not explicitly allowlisted below is ignored.
# See: docs/decision-records/org/0003-use-deny-all-gitignore-strategy.md
# =============================================================================
**

# Allow the allowlist itself so tracked scope stays auditable.
!/.gitignore

# -- Top-level repo files -----------------------------------------------------
!/.editorconfig
!/.pre-commit-config.yaml
!/AGENTS.md
!/CLAUDE.md
!/Makefile
!/README.md
!/systems

# -- GitHub configuration -----------------------------------------------------
!/.github/
!/.github/CODEOWNERS
!/.github/dependabot.yml
!/.github/workflows/
!/.github/workflows/deploy.yaml
!/.github/workflows/security.yaml
!/.github/workflows/validate.yaml

# -- Cluster: Talos machine config patches + version pinning ------------------
!/cluster/
!/cluster/config.env
!/cluster/patches/
!/cluster/patches/TDNHQ-TLOMGT01.yaml
!/cluster/patches/TDNHQ-TLOMGT02.yaml
!/cluster/patches/TDNHQ-TLOWRK01.yaml
!/cluster/patches/TDNHQ-TLOWRK02.yaml
!/cluster/patches/common.yaml
!/cluster/patches/controlplane.yaml
!/cluster/patches/worker.yaml

# -- Addons: Helm values and Kubernetes manifests -----------------------------
!/addons/
!/addons/cilium/
!/addons/cilium/values.yaml
!/addons/ingress-nginx/
!/addons/ingress-nginx/values.yaml
!/addons/metrics-server/
!/addons/metrics-server/values.yaml
!/addons/poc/
!/addons/poc/deployment.yaml
!/addons/poc/namespace.yaml
!/addons/poc/service.yaml

# -- Scripts: automation invoked by the Makefile ------------------------------
!/scripts/
!/scripts/agent-loop.ps1
!/scripts/agent-loop.sh
!/scripts/apply.sh
!/scripts/bootstrap.sh
!/scripts/generate.sh
!/scripts/health.sh
!/scripts/s3-sync.sh
!/scripts/upgrade.sh

# -- Docs: org-mirrored ADRs + repo/template ADR skeleton ---------------------
!/docs/
!/docs/decision-records/
!/docs/decision-records/README.md
!/docs/decision-records/org/
!/docs/decision-records/org/0001-use-architecture-decision-records.md
!/docs/decision-records/org/0002-adopt-diataxis-documentation-framework.md
!/docs/decision-records/org/0003-use-deny-all-gitignore-strategy.md
!/docs/decision-records/org/0004-use-renovate-for-dependency-updates.md
!/docs/decision-records/repo/
!/docs/decision-records/repo/.gitkeep
!/docs/decision-records/template/
!/docs/decision-records/template/.gitkeep
